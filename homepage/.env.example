# Supabase — Cloudflare Pages 대시보드에서 환경변수 설정 필요
# Settings > Environment variables 에서 추가
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ⚠️ Supabase 보안 체크리스트 (대시보드에서 직접 설정):
# 1. Authentication > Policies: inquiries 테이블 RLS 활성화
# 2. INSERT only for anon (상담신청 저장용)
# 3. SELECT 차단 for anon (외부에서 데이터 열람 불가)
